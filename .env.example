# Copy this file to .env (in the project root) and fill in your key.

# Required — Google Gemini API key (free tier works): https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional — only needed for the (not-yet-wired) Pinterest publishing step.
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TOKEN=
